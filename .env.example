# ══════════════════════════════════════════════════════════════════════════════
# SWASTHYA AI CORE — Environment Configuration
# Copy this file to .env and fill in all values before starting.
# The application will REFUSE TO START if any required key is missing.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────────────────────
# Set to 'production' on Render
APP_ENV=production
APP_HOST=0.0.0.0
# Note: Render automatically provides the PORT environment variable.
# PORT overrides APP_PORT.
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ── LLM Providers (REQUIRED) ───────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-large-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# ── Tavily Search (REQUIRED) ───────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here
TAVILY_BASE_URL=https://api.tavily.com

# ── Google Maps (REQUIRED for location resolution) ─────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# ── Redis (REQUIRED) ───────────────────────────────────────────────────────────
# Update with Render internal Redis URL (e.g., redis://red-xxxxx:6379)
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=21600

# ── LLM Retry Policy ──────────────────────────────────────────────────────────
GEMINI_MAX_RETRIES=3
GEMINI_TIMEOUT_SECONDS=60
MISTRAL_MAX_RETRIES=2
MISTRAL_TIMEOUT_SECONDS=60

# ── Scraping ───────────────────────────────────────────────────────────────────
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_CONCURRENT=4
